# ═══════════════════════════════════════════════════════════
# Дефолты для install-all.sh / backup-all.sh / restore-all.sh /
# deploy-from-backup.sh.
#
# STACK_DIR / WEBHOOK_DIR могут быть:
#   - относительными именами (резолвятся как ${ROOT_DIR}/<name>,
#     где ROOT_DIR — каталог, в котором лежит этот файл)
#   - абсолютными путями (используются как есть)
#
# По умолчанию — относительные имена соответствуют структуре
# репо после `git clone`: deploy/{service,postback}/.
#
# Имена *_PROJECT и WEBHOOK_VOL должны совпадать с реально
# существующими docker volumes/projects на сервере. Проверить:
#   docker volume ls | grep app_data
#   docker compose ls
# ═══════════════════════════════════════════════════════════

STACK_DIR=service
WEBHOOK_DIR=postback
STACK_PROJECT=service
WEBHOOK_PROJECT=postback
WEBHOOK_VOL=postback_app_data
BACKUP_ROOT=/home/igor/backup

# DEPLOY_USER: пользователь под которым CI/CD (GitHub Actions) заходит
# по SSH в каталог плагина для `git pull`. Получает те же ACL-права
# на wp-content/, что и REAL_USER, через service/scripts/fix-wp-perms.sh.
# Без этого после каждого restore-all.sh / install.sh / ребилда volume
# `git pull` падает с `.git/FETCH_HEAD: Permission denied`. Пусто = пропуск.
DEPLOY_USER=deployer

# ═══════════════════════════════════════════════════════════
# Optional debug / hardening overrides (E2E follow-up 2026-04-29)
#
# Эти переменные read by docker-compose.yml через ${VAR:-default}.
# Дефолты = текущее поведение, чтобы `git pull` ничего не активировал.
# Чтобы включить — раскомментируй строку и сделай `docker compose up -d`
# (для wordpress-сервиса достаточно restart, для modsecurity тоже).
#
# Не править эти строки в этом файле, если не уверен — используй
# серверный override (например, ${ROOT_DIR}/.env с теми же ключами).
# ═══════════════════════════════════════════════════════════

# A1-4 (WP_DEBUG_LOG): plugin'овые error_log() → /var/www/html/wp-content/debug.log
# (вместо stderr контейнера). Без активации WP_DEBUG (нет notice/warning spam'а
# от core/woocommerce). Включать на staging для длительных E2E прогонов.
# Default: 0 (errors → stderr, видны через `docker logs wordpress`).
# WP_DEBUG_ENABLE=1

# A1-3 (ModSec rule engine): On = реальная блокировка XSS/SQLi (HTTP 403).
# DetectionOnly = только запись в modsec_audit.log без блокировки. Перед
# переключением на On проверить недельный modsec_audit.log на ложные
# срабатывания (admin-AJAX / WC-checkout / cashback-extension):
#   docker exec modsecurity grep -c '"anomaly_score"' /var/log/modsec/modsec_audit.log
#   tail -100 /f/cash-back/deploy/service/volumes/modsec-logs/modsec_audit.log | jq .transaction.messages
# Default: DetectionOnly (текущее поведение).
# MODSEC_RULE_ENGINE=On

# A1-3 follow-up (ModSec paranoia): 1 = базовая защита (рекомендованный CRS старт).
# Поднимать до 2 только после успешного soak'а 1+неделю на On без false positives.
# Levels 3-4 — для high-security sites, требуют существенных allowlist-правил.
# Default: 1.
# MODSEC_PARANOIA=2
