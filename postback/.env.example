# ═══════════════════════════════════════════════════════════
# postback/.env — конфигурация webhook-receiver (FastAPI).
#
# Этот файл создаётся автоматически скриптом `install.sh` —
# вручную трогать не нужно, шаблон здесь для справки.
#
# `.env` под .gitignore — не коммитится.
# Регенерация после ошибки: удалить .env, запустить install.sh
# заново (он спросит подтверждение перезаписи).
#
# Compose читает .env автоматически (docker-compose.yml через
# `${VAR}` или `${VAR:?msg}` для required-полей).
# ═══════════════════════════════════════════════════════════

# ─── Обязательные (генерируется install.sh) ────────────────

# ADMIN_SECRET — пароль admin-панели (порт 8098 через SSH-туннель).
# Длина 24 символа, генерируется `openssl rand -base64 32 | tr -d '/+=\n' | head -c 24`.
# Compose сделает FAIL-LOUD если переменная пустая (`${ADMIN_SECRET:?...}`).
# Хранится в plaintext в .env — chmod 600. После смены требуется
# `docker compose up -d` (smena значения инвалидирует все session-токены).
ADMIN_SECRET=changeme_24_chars_min

# WEBHOOK_DOMAIN — поддомен для приёма постбэков от CPA-сетей.
# Должен резолвиться на сервер ДО запуска: иначе Traefik не выдаст
# Let's Encrypt сертификат и app-receiver останется unhealthy.
# Пример: webhook.example.com
WEBHOOK_DOMAIN=webhook.example.com

# ─── SMTP (для worker'а — отправка писем при alerting) ──────

# SMTP_ENV_FILE — путь к .env service-стека (где SMTP_HOST/SMTP_PORT/...).
# Worker читает их через `env_file:` директиву compose с required:false,
# поэтому при недоступности файла worker запустится, но письма не пошлёт.
# Стандартное значение — соседний service-стек:
SMTP_ENV_FILE=/path/to/service/.env

# SMTP_PASSWORD_FILE_HOST — путь на хосте к secrets/smtp_password.txt
# из service-стека. Worker монтирует как docker secret. Если файл
# отсутствует, alerting через direct-SMTP отвалится (письма пойдут
# через WP-крон fallback).
SMTP_PASSWORD_FILE_HOST=/path/to/service/secrets/smtp_password.txt

# ─── Часовой пояс ───────────────────────────────────────────

# TZ — таймзона контейнеров. UTC = единый формат timestamp'ов в логах
# и БД (WordPress конвертирует в Europe/Moscow через wp_date() при
# выводе пользователю).
TZ=UTC

# ═══════════════════════════════════════════════════════════
# Параметры БД (host/port/user/password/database/prefix) НЕ хранятся
# в .env — они записываются install.sh'ом в config.json внутри docker
# volume `postback_app_data` (mount /data в контейнере). См. install.sh
# секцию "Init config.json in volume".
# ═══════════════════════════════════════════════════════════
