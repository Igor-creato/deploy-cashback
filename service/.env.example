# ═══════════════════════════════════════════════════════════
# service/.env — переопределения для docker-compose.yml.
#
# Этот файл читается docker compose'ом автоматически (в отличие
# от cashback.env, который читается shell-скриптами install-all.sh
# / backup-all.sh).
#
# Скопируй в `.env` и редактируй. Файл `.env` под gitignore — не
# коммитится. После правок: `docker compose up -d <service>`.
#
# Управлять флагами проще через скрипты:
#   sudo bash scripts/wp-debug-log.sh on|off|status
#   sudo bash scripts/modsec-mode.sh    on|off|status
# Они идемпотентно правят .env и перезапускают нужный сервис.
# ═══════════════════════════════════════════════════════════

# A1-4: WP debug log. "1" → plugin'овые error_log() пишутся в
# /var/www/html/wp-content/debug.log (видно из хоста как
# service/volumes/wordpress/wp-content/debug.log). Без активации
# WP_DEBUG (нет notice/warning spam'а от core/woocommerce).
# Default: "0" (errors → stderr, видны через `docker logs wordpress`).
#WP_DEBUG_ENABLE=0

# A1-3: ModSecurity rule engine. "On" → реальная блокировка XSS/SQLi
# с ответом HTTP 403. "DetectionOnly" → только запись в audit log без
# блокировки. Default: "DetectionOnly" (текущее prod-поведение).
#MODSEC_RULE_ENGINE=DetectionOnly

# A1-3 follow-up: ModSec paranoia level. 1 = базовый CRS старт
# (рекомендуется до soak'а 1+ неделю на On без false positives).
# Levels 3-4 — для high-security sites + значительные local exclusions.
# Default: 1.
#MODSEC_PARANOIA=1

# nginx server_name. install-time переменная (не читается docker compose).
# Пишется install.sh'ом в .env и используется им же при envsubst-рендере
# default.conf.tpl → default.conf. Дефолт: "<DOMAIN> localhost 127.0.0.1 nginx".
# Для multi-subdomain wildcard: ".example.com localhost 127.0.0.1 nginx".
# Изменить — перезапустить install.sh ИЛИ заранее экспортировать переменную:
#   NGINX_SERVER_NAMES=".example.com localhost 127.0.0.1 nginx" sudo bash install.sh
#NGINX_SERVER_NAMES=

# Email контакта Let's Encrypt (ACME). Канонический источник правды:
# пишется install.sh'ом в .env, отсюда render-configs.sh подставляет в
# volumes/traefik/traefik.yml через `envsubst ${ACME_EMAIL}` (generated
# traefik.yml — в .gitignore). На КАЖДОМ сервере должен присутствовать
# (staging и prod — разные значения, т.к. разные домены/контакты).
# Менять — `ACME_EMAIL=<email>` в .env, затем: bash render-configs.sh
# (рестарт traefik не нужен — acme.json/сертификаты не трогаются).
#ACME_EMAIL=
