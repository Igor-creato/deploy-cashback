# ───── Target stand ─────
# Базовый URL стенда (через Traefik, с SSL).
BASE_URL=https://stand.example.com

# Webhook receiver (тот же домен или поддомен).
WEBHOOK_URL=https://stand.example.com

# Слаг сети (см. admin-панель постбэков), 32-байтный URL-safe секрет пути.
NETWORK_SLUG=adm
WEBHOOK_SECRET_PATH=  # из postback config.json: networks.<slug>.secret_path
HMAC_SECRET=          # пусто, если signing.enabled=false на network'е
WEBHOOK_METHOD=GET    # GET | POST — должен совпадать с networks.<slug>.webhook_method

# ───── SSH доступ к стенду (для seed/teardown через wp-cli) ─────
SSH_HOST=stand.example.com
SSH_PORT=22
SSH_USER=deployer
SSH_KEY=~/.ssh/id_ed25519
WP_CONTAINER=wordpress
REDIS_CONTAINER=redis

# ───── Тестовые учётные данные ─────
# Пароль для всех loadtest_user_* (создаётся в seed_users.php).
LOADTEST_PASS=Loadtest!2026SuperSecret

# Сколько тестовых юзеров создавать (default 200).
LOADTEST_USER_COUNT=200

# Сколько товаров (default 50).
LOADTEST_PRODUCT_COUNT=50

# Сколько кликов в click_log (default 200).
LOADTEST_CLICK_COUNT=200

# ───── Метрики ─────
# Куда k6 пушит метрики (VictoriaMetrics на стенде, доступная по сети).
# Если VM закрыта firewall'ом — поднять SSH-туннель и указать localhost.
VM_REMOTE_WRITE=http://stand.example.com:8428/api/v1/write

# Grafana annotations API (для маркеров начала/конца прогона).
GRAFANA_URL=http://stand.example.com:3000
GRAFANA_API_TOKEN=
