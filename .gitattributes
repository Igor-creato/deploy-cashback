# Линукс-скрипты должны чекаут-ниться с LF независимо от платформы.
# Иначе CRLF в shebang ломает выполнение на сервере:
#   /bin/bash^M: bad interpreter: No such file or directory
*.sh           text eol=lf
*.bash         text eol=lf
*.cnf          text eol=lf
*.conf         text eol=lf
*.yml          text eol=lf
*.yaml         text eol=lf
*.toml         text eol=lf
*.env          text eol=lf
.env*          text eol=lf
Dockerfile     text eol=lf
docker-entrypoint*.sh text eol=lf

# Бинарные — никаких преобразований.
*.png          binary
*.jpg          binary
*.gz           binary
*.tar          binary

# Тесты не нужны в production-артефактах (`git archive` / тарболы).
# ВНИМАНИЕ: export-ignore НЕ работает для `git clone`/`git pull`.
# Для прод-сервера, который тянет код через git pull, тесты исключаются
# через `git sparse-checkout` — см. README.md.
tests/             export-ignore
postback/tests/    export-ignore
